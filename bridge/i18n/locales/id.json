      "source_hash": "6da94e3206f9ce25",
      "auto_translated": true,
      "reviewed": false
    },
    "debate.consensus_low": {
      "text": "Para penyedia memberikan respons yang sangat berbeda (tumpang tindih kata: {overlap}). Bandingkan respons di atas untuk perspektif berbeda.",
