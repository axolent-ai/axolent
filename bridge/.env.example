# Telegram Bot Token (Pflicht)
# Hol dir einen via @BotFather in Telegram: /newbot
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Whitelist (Pflicht: Komma-getrennte Telegram-User-IDs)
# Hol deine User-ID via @userinfobot in Telegram
WHITELIST_USER_IDS=123456789

# Optional: erlaubt allen Usern den Bot zu nutzen (NUR fuer Dev)
# ALLOW_ALL_USERS=true
