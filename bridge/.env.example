# Telegram Bot Token (required)
# Get one via @BotFather in Telegram: /newbot
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Whitelist (required: comma-separated Telegram user IDs)
# Get your user ID via @userinfobot in Telegram
# Replace with your actual Telegram user IDs:
WHITELIST_USER_IDS=YOUR_TELEGRAM_USER_ID

# Optional: allow all users to use the bot (DEV ONLY)
# ALLOW_ALL_USERS=true
# AXOLENT_DEV_MODE=true   # Required when ALLOW_ALL_USERS=true
# Legacy: JARVIS_DEV_MODE is still recognized, but please migrate to AXOLENT_DEV_MODE

# Optional: subprocess TTL in seconds (default: 3600 = 1 hour)
# CLAUDE_SUBPROCESS_TTL_SECONDS=3600

# Optional: model for the Claude Process Pool (default: claude-sonnet-4-6)
# Without this setting the CLI would use the user default (often Opus = 3-5x slower).
# CLAUDE_POOL_MODEL=claude-sonnet-4-6

# Ollama auto-start at bot startup (default: true)
# Set to false to disable automatic Ollama service start
# AXOLENT_OLLAMA_AUTOSTART=true

# Multi-AI Debate configuration (R10)
# Comma-separated list of providers used for /debate
# Default: all available
# DEBATE_PROVIDERS=claude_persistent,ollama

# Streaming mode (default: telegram)
# "telegram": burst-then-throttle (fast first 5 edits, then gradual slowdown)
# "local": no throttling at all (for desktop app / local socket streaming)
# AXOLENT_STREAMING_MODE=telegram

# Fallback Resolver: automatic provider failover (Phase 2b)
# Comma-separated provider names per slot. First = primary, rest = fallbacks.
# AXOLENT_FALLBACK_CHAIN_CHAT=claude_persistent,ollama_local
# AXOLENT_FALLBACK_CHAIN_CODE=claude_persistent,ollama_local
# AXOLENT_FALLBACK_CHAIN_DEFAULT=claude_persistent,ollama_local
# AXOLENT_FALLBACK_TIMEOUT_SECONDS=30
# AXOLENT_FALLBACK_USER_NOTICE_THRESHOLD=2
